# ─── OpenAI Auth ─────────────────────────────────────────────────────────────
# OpenClaw uses OAuth for OpenAI authentication — no API key needed here.
# Run `openclaw onboard` and it will open a browser to log you in.

# ─── Telegram ────────────────────────────────────────────────────────────────
# One bot handles all 5 agents via routing.
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=
