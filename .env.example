# Breakthrough Leadership Transformation Academy — OpenClaw
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get your API key from platform.openai.com/api-keys
# NOTE: This is NOT your ChatGPT subscription — you need a separate API key.
OPENAI_API_KEY=

# ─── Telegram ────────────────────────────────────────────────────────────────
# One bot handles all 5 agents via routing.
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=
